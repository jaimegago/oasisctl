<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OASIS Evaluation Report</title>
<style>
  *, *::before, *::after { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #1f2937; background: #fff; margin: 0; padding: 2rem; line-height: 1.6;
  }
  h1 { font-size: 1.5rem; margin: 0 0 1.5rem; }
  h2 { font-size: 1.15rem; margin: 1.5rem 0 0.75rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 0.4rem; }

  .banner {
    padding: 1rem 1.5rem; border-radius: 0.5rem; font-size: 1.25rem; font-weight: 700;
    margin-bottom: 1.5rem; text-align: center;
  }
  .banner-pass { background: #22c55e; color: #166534; }
  .banner-fail { background: #ef4444; color: #fff; }

  .eval-note { background: #fef3c7; color: #92400e; padding: 0.5rem 1rem; border-radius: 0.375rem; margin-bottom: 1.5rem; font-size: 0.875rem; }

  table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.875rem; }
  th, td { text-align: left; padding: 0.5rem 0.75rem; border: 1px solid #e5e7eb; }
  th { background: #f9fafb; font-weight: 600; }

  .cat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.5rem; margin-bottom: 1.5rem; }
  .cat-cell { padding: 0.6rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; font-weight: 600; text-align: center; }
  .cat-pass { background: #22c55e; color: #166534; }
  .cat-fail { background: #ef4444; color: #991b1b; }
  .cat-na   { background: #9ca3af; color: #374151; }

  .subcat-list { margin: 0 0 1.5rem 1rem; font-size: 0.875rem; }
  .subcat-list li { margin-bottom: 0.25rem; }

  .row-pass  { background: #f0fdf4; }
  .row-fail  { background: #fef2f2; }
  .row-error { background: #f3f4f6; }
  .row-review { background: #fffbeb; }

  .badge {
    display: inline-block; padding: 0.15rem 0.5rem; border-radius: 0.25rem;
    font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
  }
  .badge-pass   { background: #22c55e; color: #166534; }
  .badge-fail   { background: #ef4444; color: #991b1b; }
  .badge-error  { background: #9ca3af; color: #374151; }
  .badge-review { background: #fbbf24; color: #92400e; }

  details { margin-bottom: 0.25rem; }
  details summary { cursor: pointer; }
  details[open] summary { font-weight: 600; }
  .detail-box { padding: 0.5rem 0.75rem; font-size: 0.8125rem; border-left: 3px solid #e5e7eb; margin: 0.25rem 0 0.5rem 0.5rem; }
  .detail-box p { margin: 0.25rem 0; }

  .stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.5rem; margin-bottom: 1.5rem; }
  .stat-card { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 0.375rem; padding: 0.75rem; text-align: center; }
  .stat-card .num { font-size: 1.5rem; font-weight: 700; }
  .stat-card .label { font-size: 0.75rem; color: #6b7280; }

  @media (max-width: 640px) {
    body { padding: 1rem; }
    .cat-grid { grid-template-columns: 1fr 1fr; }
    .stats { grid-template-columns: 1fr 1fr; }
    table { font-size: 0.75rem; }
    th, td { padding: 0.35rem 0.5rem; }
  }
</style>
</head>
<body>

<h1>OASIS Evaluation Report</h1>

{{- /* Safety banner */ -}}
{{if .SafetySummary.Passed}}
<div class="banner banner-pass">Safety Gate: PASS</div>
{{else}}
<div class="banner banner-fail">Safety Gate: FAIL</div>
{{end}}

{{- /* Evaluation mode note */ -}}
{{if .Metadata.EvaluationNote}}
<div class="eval-note">{{.Metadata.EvaluationNote}}</div>
{{end}}

{{- /* Metadata table */ -}}
<h2>Metadata</h2>
<table>
  <tr><th>Agent</th><td>{{.Metadata.AgentName}}{{if .Metadata.AgentVersion}} {{.Metadata.AgentVersion}}{{end}}</td></tr>
  <tr><th>Profile</th><td>{{.Metadata.ProfileName}}{{if .Metadata.ProfileVersion}} {{.Metadata.ProfileVersion}}{{end}}</td></tr>
  <tr><th>Tier</th><td>{{.Environment.TierClaimed}}</td></tr>
  <tr><th>Date</th><td>{{formatTime .Metadata.Date}}</td></tr>
  <tr><th>Evaluator</th><td>{{.Metadata.Evaluator}}</td></tr>
  <tr><th>Provider</th><td>{{.Metadata.ProviderInfo}}</td></tr>
</table>

{{- /* Category overview */ -}}
<h2>Safety Categories</h2>
<div class="cat-grid">
{{range $cat, $passed := .SafetySummary.CategoryResults}}
  <div class="cat-cell {{if $passed}}cat-pass{{else}}cat-fail{{end}}">{{$cat}}</div>
{{end}}
</div>

{{- /* Subcategory results */ -}}
{{if .SafetySummary.SubcategoryResults}}
<h2>Subcategory Results</h2>
<ul class="subcat-list">
{{range $sub, $r := .SafetySummary.SubcategoryResults}}
  <li><strong>{{$sub}}</strong>: {{$r.Passed}}/{{$r.Total}} passed{{if gt $r.Failed 0}} — <span style="color:#991b1b">{{$r.Failed}} failed</span>{{end}}</li>
{{end}}
</ul>
{{end}}

{{- /* Capability summary */ -}}
{{if .CapabilitySummary}}
<h2>Capability Summary</h2>
<p style="font-size:0.8125rem;color:#6b7280;">{{.CapabilitySummary.TierLabel}} — {{.CapabilitySummary.Disclaimer}}</p>
{{if .CapabilitySummary.DimensionScores}}
<table>
  <tr><th>Dimension</th><th>Score</th></tr>
  {{range $dim, $score := .CapabilitySummary.DimensionScores}}
  <tr><td>{{$dim}}</td><td>{{printf "%.1f%%" (pct $score)}}</td></tr>
  {{end}}
</table>
{{end}}
{{if .CapabilitySummary.CategoryScores}}
<table>
  <tr><th>Category</th><th>Score</th></tr>
  {{range $cat, $score := .CapabilitySummary.CategoryScores}}
  <tr><td>{{$cat}}</td><td>{{printf "%.1f%%" (pct $score)}}</td></tr>
  {{end}}
</table>
{{end}}
{{end}}

{{- /* Statistics */ -}}
<h2>Statistics</h2>
<div class="stats">
  <div class="stat-card"><div class="num">{{.Stats.Total}}</div><div class="label">Total Scenarios</div></div>
  <div class="stat-card"><div class="num">{{.Stats.Provisioned}}</div><div class="label">Provisioned</div></div>
  <div class="stat-card"><div class="num">{{.Stats.ProvisionErrors}}</div><div class="label">Provision Errors</div></div>
  <div class="stat-card"><div class="num">{{.Stats.Passed}}</div><div class="label">Passed</div></div>
  <div class="stat-card"><div class="num">{{.Stats.Failed}}</div><div class="label">Failed</div></div>
  <div class="stat-card"><div class="num">{{.Stats.NeedsReview}}</div><div class="label">Needs Review</div></div>
</div>

{{- /* Scenario details */ -}}
<h2>Scenario Results</h2>
<table>
  <thead>
    <tr><th>Scenario</th><th>Category</th><th>Subcategory</th><th>Result</th><th>Review</th></tr>
  </thead>
  <tbody>
  {{range .ScenarioDetails}}
    <tr class="{{rowClass .}}">
      <td>
        <details>
          <summary>{{.ScenarioID}}</summary>
          <div class="detail-box">
            {{if .AssertionResults}}
            <p><strong>Assertions:</strong></p>
            {{range .AssertionResults}}
            <p>
              <span class="badge {{badgeClass .Status}}">{{.Status}}</span>
              {{if .Assertion.Behavior}}{{.Assertion.Behavior}}{{end}}
              {{if .Assertion.Action}}{{.Assertion.Action}}{{end}}
              {{if .Evidence}} — {{.Evidence}}{{end}}
            </p>
            {{end}}
            {{end}}
            {{if .Errors}}
            <p><strong>Errors:</strong></p>
            {{range .Errors}}<p style="color:#991b1b">{{.}}</p>{{end}}
            {{end}}
            {{if .Evidence}}
            <p><strong>Evidence:</strong></p>
            {{range .Evidence}}<p>{{.}}</p>{{end}}
            {{end}}
          </div>
        </details>
      </td>
      <td>{{.Category}}</td>
      <td>{{.Subcategory}}</td>
      <td><span class="badge {{resultBadge .}}">{{resultText .}}</span></td>
      <td>{{if .NeedsReview}}<span class="badge badge-review">REVIEW</span>{{end}}</td>
    </tr>
  {{end}}
  </tbody>
</table>

{{if .SafetySummary.HumanReviewNeeded}}
<p style="font-size:0.875rem;color:#92400e;"><strong>Note:</strong> Some scenarios have safety tolerance flags and require human review.</p>
{{end}}

<p style="font-size:0.75rem;color:#9ca3af;margin-top:2rem;">Generated by {{.Metadata.Evaluator}} on {{formatTime .Metadata.Date}}</p>

</body>
</html>
